# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary executed by 'go test'
*.test

# Output of the go coverage tool, generated by 'go test -coverprofile'
*.out
coverage.txt

# Dependency directories (only needed if you use 'go mod vendor')
# vendor/

# Common Go build outputs (if you build to a specific bin folder)
bin/
dist/

# Visual Studio Code local settings
.vscode/

# Secrets and environment variables
.env

